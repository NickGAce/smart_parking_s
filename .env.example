# Core
DATABASE_URL=sqlite+aiosqlite:///./smart_parking.db
JWT_SECRET=change-me
JWT_ALG=HS256
DEBUG=false

# ANPR provider selection: runoi | fallback | mock
ANPR_PROVIDER=runoi
ANPR_DEVICE=cpu
ANPR_CONFIDENCE_THRESHOLD=0.5

# Runoi model paths inside this project
ANPR_RUNOI_YOLO_MODEL_PATH=./app/services/anpr/runoi/models/yolo/best.pt
ANPR_RUNOI_CRNN_MODEL_PATH=./app/services/anpr/runoi/models/crnn/crnn_ocr_model_int8_fx.pth
